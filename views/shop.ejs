<%- include('partials/header') %>

<div class="py-10">
    <h1 class="text-4xl font-extrabold tracking-tighter uppercase mb-2">Shop All</h1>
    <p class="text-gray-500 mb-10">Everything Unashamed. One place.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <% products.forEach(product => { %>
            <div class="group flex flex-col">
                <div class="overflow-hidden bg-gray-100 rounded-md mb-4 aspect-[4/5]">
                    <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
                </div>
                <div class="flex justify-between items-start mb-4">
                    <h3 class="text-md font-bold text-gray-900 leading-tight pr-4"><%= product.name %></h3>
                    <p class="text-md font-medium text-gray-600 whitespace-nowrap">KES <%= product.price %></p>
                </div>
                <form action="/checkout" method="POST" class="mt-auto">
                    <input type="hidden" name="productId" value="<%= product.id %>">
                    <input type="hidden" name="quantity" value="1">
                    <button type="submit" class="w-full bg-black text-white py-2 text-sm font-bold uppercase tracking-widest hover:bg-gray-800 transition">
                        Buy Now
                    </button>
                </form>
            </div>
        <% }) %>
    </div>
</div>

<%- include('partials/footer') %>