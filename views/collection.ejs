<%- include('partials/header') %>

<div class="relative bg-black text-white py-24 px-6 rounded-lg mb-12 mt-4 text-center overflow-hidden">
    <img src="<%= collection.image %>" alt="" class="absolute inset-0 w-full h-full object-cover opacity-30">
    <div class="relative z-10">
        <h1 class="text-5xl md:text-6xl font-extrabold tracking-tighter mb-4 uppercase"><%= collection.name %></h1>
        <p class="text-lg text-gray-300 max-w-2xl mx-auto"><%= collection.description %></p>
    </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10 mb-20">
    <% products.forEach(product => { %>
        <div class="group flex flex-col">
            <div class="overflow-hidden bg-gray-100 rounded-md mb-4 aspect-[4/5]">
                <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
            </div>
            <div class="flex justify-between items-start mb-4">
                <h3 class="text-lg font-bold text-gray-900 leading-tight pr-4"><%= product.name %></h3>
                <p class="text-lg font-medium text-gray-600 whitespace-nowrap">KES <%= product.price %></p>
            </div>
            <form action="/checkout" method="POST" class="mt-auto">
                <input type="hidden" name="productId" value="<%= product.id %>">
                <input type="hidden" name="quantity" value="1">
                <div class="flex gap-2">
                    <button type="button" 
                        class="add-to-cart-btn flex-1 bg-white text-black border-2 border-black py-3 font-bold uppercase tracking-widest hover:bg-gray-100 transition"
                        data-id="<%= product.id %>"
                        data-name="<%= product.name %>"
                        data-price="<%= product.price %>"
                        data-image="<%= product.image %>">
                        Add to Cart
                    </button>
                    <a href="/capture-lead" 
                        class="buy-now-btn flex-1 bg-black text-white py-3 font-bold uppercase tracking-widest hover:bg-gray-800 transition text-center block"
                        data-id="<%= product.id %>"
                        data-name="<%= product.name %>"
                        data-price="<%= product.price %>"
                        data-image="<%= product.image %>">
                        Buy Now
                    </a>
                </div>
            </form>
        </div>
    <% }) %>
</div>

<%- include('partials/footer') %>