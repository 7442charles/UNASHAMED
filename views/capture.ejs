<%- include('partials/header') %>

<div class="max-w-4xl mx-auto py-10">
    <h1 class="text-4xl font-extrabold tracking-tighter uppercase mb-2">Complete Your Order</h1>
    <p class="text-gray-500 mb-10">Review your items and share your details to place an order via WhatsApp.</p>

    <div class="grid grid-cols-1 md:grid-cols-5 gap-8">
        <!-- Left: Cart Summary -->
        <div class="md:col-span-3">
            <h2 class="text-lg font-bold uppercase tracking-wider mb-4 border-b border-gray-200 pb-2">Order Summary</h2>
            <div id="capture-cart-items" class="space-y-3">
                <!-- JS will populate this -->
            </div>
            <div id="capture-cart-empty" class="text-center text-gray-400 py-12 hidden">
                <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                <p class="text-sm font-medium">Your cart is empty</p>
                <a href="/shop" class="text-sm text-black underline mt-2 inline-block">Shop now</a>
            </div>
            <div class="border-t border-gray-200 mt-4 pt-4 flex justify-between items-center">
                <span class="text-lg font-bold uppercase">Total</span>
                <span id="capture-cart-total" class="text-2xl font-black">KES 0</span>
            </div>
        </div>

        <!-- Right: Customer Details Form -->
        <div class="md:col-span-2">
            <h2 class="text-lg font-bold uppercase tracking-wider mb-4 border-b border-gray-200 pb-2">Your Details</h2>
            <form id="order-form" class="space-y-4">
                <div>
                    <label for="customer-name" class="block text-sm font-bold text-gray-700 mb-1">Full Name</label>
                    <input type="text" id="customer-name" required
                        class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-black focus:border-black outline-none"
                        placeholder="e.g. Jane Doe">
                </div>
                <div>
                    <label for="customer-phone" class="block text-sm font-bold text-gray-700 mb-1">Phone Number (WhatsApp)</label>
                    <input type="tel" id="customer-phone" required
                        class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-black focus:border-black outline-none"
                        placeholder="e.g. 254712345678">
                </div>
                <div>
                    <label for="customer-address" class="block text-sm font-bold text-gray-700 mb-1">Delivery Address</label>
                    <textarea id="customer-address" rows="3" required
                        class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-black focus:border-black outline-none resize-none"
                        placeholder="e.g. 123 Kenyatta Avenue, Nairobi"></textarea>
                </div>
                <button type="submit" id="place-order-btn"
                    class="w-full bg-green-600 text-white py-4 font-bold uppercase tracking-widest hover:bg-green-700 transition rounded-lg text-sm flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    Place Order via WhatsApp
                </button>
            </form>
            <p class="text-xs text-gray-400 mt-3 text-center">
                By placing the order, you'll be redirected to WhatsApp to send your order to us.
            </p>
        </div>
    </div>
</div>

<script>
    // Get or create session ID for cart tracking
    function getSessionId() {
        let sessionId = localStorage.getItem('unashamed_session_id');
        if (!sessionId) {
            sessionId = 'sess_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
            localStorage.setItem('unashamed_session_id', sessionId);
        }
        return sessionId;
    }

    // Load cart from localStorage and render order summary
    function loadCartForCapture() {
        let cart = [];
        try {
            cart = JSON.parse(localStorage.getItem('unashamed_cart')) || [];
        } catch(e) { cart = []; }

        const container = document.getElementById('capture-cart-items');
        const emptyMsg = document.getElementById('capture-cart-empty');
        const totalEl = document.getElementById('capture-cart-total');
        const submitBtn = document.getElementById('place-order-btn');

        if (!cart || cart.length === 0) {
            container.innerHTML = '';
            emptyMsg.classList.remove('hidden');
            totalEl.textContent = 'KES 0';
            submitBtn.disabled = true;
            submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
            return;
        }

        emptyMsg.classList.add('hidden');
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');

        container.innerHTML = cart.map(item => `
            <div class="flex gap-3 p-3 bg-gray-50 rounded-lg">
                <img src="${item.image}" alt="${item.name}" class="w-16 h-16 object-cover rounded flex-shrink-0">
                <div class="flex-1 min-w-0">
                    <h4 class="text-sm font-bold text-gray-900">${item.name}</h4>
                    <p class="text-sm text-gray-600">KES ${Number(item.price).toLocaleString()} × ${item.quantity}</p>
                    <p class="text-sm font-bold text-gray-900 mt-1">KES ${(Number(item.price) * item.quantity).toLocaleString()}</p>
                </div>
            </div>
        `).join('');

        const total = cart.reduce((sum, item) => sum + (Number(item.price) * item.quantity), 0);
        totalEl.textContent = `KES ${total.toLocaleString()}`;
        
        // Track cart on server for abandonment analytics
        trackCartOnServer(cart);
    }

    // Send cart data to server for abandonment tracking
    function trackCartOnServer(cart) {
        const sessionId = getSessionId();
        const name = document.getElementById('customer-name')?.value || '';
        const phone = document.getElementById('customer-phone')?.value || '';
        const address = document.getElementById('customer-address')?.value || '';
        
        const items = cart.map(item => ({
            product_id: item.id,
            name: item.name,
            quantity: item.quantity,
            price: item.price
        }));

        fetch('/api/track-cart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                session_id: sessionId,
                items: items,
                customer_name: name || null,
                customer_phone: phone || null,
                customer_address: address || null
            })
        }).catch(err => console.error('Track cart error:', err));
    }

    // Build WhatsApp message from cart + form data
    function buildWhatsAppMessage(name, phone, address, cart) {
        const now = new Date();
        const dateStr = now.toLocaleDateString('en-KE', { 
            day: 'numeric', month: 'long', year: 'numeric',
            hour: '2-digit', minute: '2-digit'
        });

        let itemsList = cart.map((item, i) => 
            `${i + 1}. *${item.name}* × ${item.quantity} — KES ${(Number(item.price) * item.quantity).toLocaleString()}`
        ).join('\n');

        const total = cart.reduce((sum, item) => sum + (Number(item.price) * item.quantity), 0);

        return [
            `🛑 *NEW ORDER — UNASHAMED* 🛑`,
            ``,
            `📅 *Date:* ${dateStr}`,
            ``,
            `👤 *Customer Details:*`,
            `   • Name: ${name}`,
            `   • Phone: ${phone}`,
            `   • Address: ${address}`,
            ``,
            `📦 *ORDER SUMMARY:*`,
            `${itemsList}`,
            ``,
            `💵 *Total: KES ${total.toLocaleString()}*`,
            ``,
            `⚡ *Payment:* M-Pesa on Delivery`,
            `📍 *Delivery:* To be confirmed`,
            ``,
            `_Thank you for shopping Unashamed!_`
        ].join('\n');
    }

    // Handle form submission
    document.getElementById('order-form').addEventListener('submit', function(e) {
        e.preventDefault();

        const name = document.getElementById('customer-name').value.trim();
        const phone = document.getElementById('customer-phone').value.trim();
        const address = document.getElementById('customer-address').value.trim();

        if (!name || !phone || !address) {
            alert('Please fill in all your details.');
            return;
        }

        let cart = [];
        try {
            cart = JSON.parse(localStorage.getItem('unashamed_cart')) || [];
        } catch(e) { cart = []; }

        if (!cart.length) {
            alert('Your cart is empty. Add some items first!');
            window.location.href = '/shop';
            return;
        }

        const message = buildWhatsAppMessage(name, phone, address, cart);
        const encodedMessage = encodeURIComponent(message);

        // Get the seller WhatsApp number from the server-rendered variable
        const sellerNumber = '<%= SELLER_WHATSAPP %>'.replace(/[^0-9]/g, '');
        const waUrl = `https://wa.me/${sellerNumber}?text=${encodedMessage}`;
        
        // Mark cart as converted before clearing
        const sessionId = getSessionId();
        fetch('/api/convert-cart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ session_id: sessionId })
        }).catch(err => console.error('Convert cart error:', err));

        // Clear the cart after order placement
        localStorage.removeItem('unashamed_cart');

        // Redirect to WhatsApp
        window.open(waUrl, '_blank');

        // Show success message on page
        document.getElementById('order-form').innerHTML = `
            <div class="text-center py-12">
                <svg class="w-16 h-16 mx-auto mb-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <h3 class="text-xl font-bold mb-2">Order Ready!</h3>
                <p class="text-gray-500 mb-4">You'll be redirected to WhatsApp to send your order.</p>
                <p class="text-sm text-gray-400">Didn't open? <a href="${waUrl}" target="_blank" class="text-green-600 underline font-bold">Click here to open WhatsApp</a></p>
                <a href="/shop" class="inline-block mt-6 bg-black text-white px-8 py-3 font-bold uppercase tracking-widest hover:bg-gray-800 transition">Continue Shopping</a>
            </div>
        `;
    });

    // Track cart on form field change (update name/phone/address)
    document.getElementById('customer-name').addEventListener('input', function() {
        let cart = [];
        try { cart = JSON.parse(localStorage.getItem('unashamed_cart')) || []; } catch(e) {}
        if (cart.length) trackCartOnServer(cart);
    });
    document.getElementById('customer-phone').addEventListener('input', function() {
        let cart = [];
        try { cart = JSON.parse(localStorage.getItem('unashamed_cart')) || []; } catch(e) {}
        if (cart.length) trackCartOnServer(cart);
    });
    document.getElementById('customer-address').addEventListener('input', function() {
        let cart = [];
        try { cart = JSON.parse(localStorage.getItem('unashamed_cart')) || []; } catch(e) {}
        if (cart.length) trackCartOnServer(cart);
    });

    // Initialize
    loadCartForCapture();
</script>

<%- include('partials/footer') %>

