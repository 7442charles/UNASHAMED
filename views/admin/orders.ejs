<% currentPage = 'orders'; %>
<%- include('partials/admin-head') %>

<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-3xl font-extrabold tracking-tighter uppercase">Orders</h1>
        <p class="text-gray-500 text-sm mt-1">View and manage customer orders.</p>
    </div>

<!-- Status Filter -->
<div class="flex flex-wrap gap-2 mb-6">
    <a href="/admin/orders" class="px-4 py-2 rounded-lg text-sm font-bold uppercase tracking-wider <%= currentStatus === 'all' ? 'bg-black text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50' %>">All</a>
    <a href="/admin/orders?status=pending" class="px-4 py-2 rounded-lg text-sm font-bold uppercase tracking-wider <%= currentStatus === 'pending' ? 'bg-yellow-400 text-black' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50' %>">Pending</a>
    <a href="/admin/orders?status=confirmed" class="px-4 py-2 rounded-lg text-sm font-bold uppercase tracking-wider <%= currentStatus === 'confirmed' ? 'bg-blue-500 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50' %>">Confirmed</a>
    <a href="/admin/orders?status=shipped" class="px-4 py-2 rounded-lg text-sm font-bold uppercase tracking-wider <%= currentStatus === 'shipped' ? 'bg-purple-500 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50' %>">Shipped</a>
    <a href="/admin/orders?status=delivered" class="px-4 py-2 rounded-lg text-sm font-bold uppercase tracking-wider <%= currentStatus === 'delivered' ? 'bg-green-500 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50' %>">Delivered</a>
    <a href="/admin/orders?status=cancelled" class="px-4 py-2 rounded-lg text-sm font-bold uppercase tracking-wider <%= currentStatus === 'cancelled' ? 'bg-red-500 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50' %>">Cancelled</a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-100">
                    <th class="text-left py-4 px-6 font-bold text-gray-500 uppercase tracking-wider text-xs">Order #</th>
                    <th class="text-left py-4 px-6 font-bold text-gray-500 uppercase tracking-wider text-xs">Customer</th>
                    <th class="text-left py-4 px-6 font-bold text-gray-500 uppercase tracking-wider text-xs">Phone</th>
                    <th class="text-left py-4 px-6 font-bold text-gray-500 uppercase tracking-wider text-xs">Items</th>
                    <th class="text-left py-4 px-6 font-bold text-gray-500 uppercase tracking-wider text-xs">Total</th>
                    <th class="text-left py-4 px-6 font-bold text-gray-500 uppercase tracking-wider text-xs">Status</th>
                    <th class="text-left py-4 px-6 font-bold text-gray-500 uppercase tracking-wider text-xs">Date</th>
                    <th class="text-right py-4 px-6 font-bold text-gray-500 uppercase tracking-wider text-xs">Action</th>
                </tr>
            </thead>
            <tbody>
                <% if (orders.length === 0) { %>
                    <tr>
                        <td colspan="8" class="py-12 text-center text-gray-400">
                            <p class="font-medium">No orders found</p>
                        </td>
                    </tr>
                <% } else { %>
                    <% orders.forEach(function(order) { %>
                        <tr class="border-b border-gray-50 hover:bg-gray-50 transition">
                            <td class="py-4 px-6 font-bold">#<%= order.id %></td>
                            <td class="py-4 px-6"><%= order.customer_name %></td>
                            <td class="py-4 px-6"><%= order.customer_phone %></td>
                            <td class="py-4 px-6"><%= order.item_count %></td>
                            <td class="py-4 px-6 font-bold">KES <%= Number(order.total).toLocaleString() %></td>
                            <td class="py-4 px-6">
                                <span class="text-xs px-2 py-1 rounded-full font-medium 
                                    <%= order.status === 'pending' ? 'bg-yellow-100 text-yellow-800' : '' %>
                                    <%= order.status === 'confirmed' ? 'bg-blue-100 text-blue-800' : '' %>
                                    <%= order.status === 'shipped' ? 'bg-purple-100 text-purple-800' : '' %>
                                    <%= order.status === 'delivered' ? 'bg-green-100 text-green-800' : '' %>
                                    <%= order.status === 'cancelled' ? 'bg-red-100 text-red-800' : '' %>
                                ">
                                    <%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
                                </span>
                            </td>
                            <td class="py-4 px-6 text-xs text-gray-500"><%= new Date(order.created_at).toLocaleDateString() %></td>
                            <td class="py-4 px-6 text-right">
                                <a href="/admin/orders/<%= order.id %>" class="text-xs font-bold text-black hover:underline">View</a>
                            </td>
                        </tr>
                    <% }); %>
                <% } %>
            </tbody>
        </table>
    </div>

<%- include('partials/admin-foot') %>
