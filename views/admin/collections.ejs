<% currentPage = 'collections'; %>
<%- include('partials/admin-head') %>

<!-- Page Header -->
<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-3xl font-extrabold tracking-tighter uppercase">Collections</h1>
        <p class="text-gray-500 text-sm mt-1">Organize products into collections.</p>
    </div>
    <a href="/admin/collections/add" class="bg-black text-white px-6 py-3 rounded-lg font-bold uppercase tracking-wider text-sm hover:bg-gray-800 transition flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Add Collection
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% if (collections.length === 0) { %>
        <div class="col-span-full text-center py-12 text-gray-400">
            <p class="font-medium">No collections yet</p>
            <a href="/admin/collections/add" class="text-sm text-black underline mt-2 inline-block">Create your first collection</a>
        </div>
    <% } else { %>
        <% collections.forEach(function(collection) { %>
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden group">
                <div class="aspect-[16/9] bg-gray-100 overflow-hidden">
                    <img src="<%= collection.image || '/images/Work_in_progress.webp' %>" alt="<%= collection.name %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                </div>
                <div class="p-5">
                    <div class="flex items-center justify-between mb-2">
                        <h3 class="font-bold text-gray-900"><%= collection.name %></h3>
                        <span class="text-xs px-2 py-1 rounded-full font-medium <%= collection.is_active ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-500' %>">
                            <%= collection.is_active ? 'Active' : 'Inactive' %>
                        </span>
                    </div>
                    <p class="text-sm text-gray-500 mb-1">Slug: <%= collection.slug %></p>
                    <p class="text-sm text-gray-500"><%= collection.product_count %> product(s)</p>
                    <div class="flex items-center gap-2 mt-4 pt-4 border-t border-gray-100">
                        <a href="/admin/collections/edit/<%= collection.id %>" class="flex-1 text-center py-2 border border-gray-300 rounded-lg text-sm font-bold hover:bg-gray-50 transition">Edit</a>
                        <form action="/admin/collections/delete/<%= collection.id %>" method="POST" onsubmit="return confirm('Delete this collection?')" class="flex-1">
                            <button type="submit" class="w-full py-2 border border-red-200 text-red-500 rounded-lg text-sm font-bold hover:bg-red-50 transition">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        <% }); %>
    <% } %>
</div>

<%- include('partials/admin-foot') %>
