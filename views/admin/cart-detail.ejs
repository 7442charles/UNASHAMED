<% currentPage = 'carts'; %>
<%- include('partials/admin-head') %>

<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-3xl font-extrabold tracking-tighter uppercase">Cart #<%= cart.id %></h1>
        <p class="text-gray-500 text-sm mt-1">Created: <%= new Date(cart.created_at).toLocaleDateString('en-KE', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
    </div>
    <a href="/admin/carts" class="text-sm text-gray-500 hover:text-black transition font-medium">&larr; Back to Carts</a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Cart Items -->
    <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider">Cart Items (<%= items.length %>)</h3>
                <span class="text-xs px-3 py-1 rounded-full font-medium 
                    <%= cart.status === 'active' ? 'bg-blue-100 text-blue-800' : '' %>
                    <%= cart.status === 'abandoned' ? 'bg-orange-100 text-orange-800' : '' %>
                    <%= cart.status === 'converted' ? 'bg-green-100 text-green-800' : '' %>
                ">
                    <%= cart.status.charAt(0).toUpperCase() + cart.status.slice(1) %>
                </span>
            </div>
            
            <% if (items.length === 0) { %>
                <p class="text-gray-400 text-sm py-8 text-center">No items in this cart.</p>
            <% } else { %>
                <div class="space-y-3">
                    <% items.forEach(function(item) { %>
                        <div class="flex items-center gap-4 p-3 bg-gray-50 rounded-lg">
                            <% if (item.product_image) { %>
                                <img src="<%= item.product_image %>" alt="<%= item.product_name %>" class="w-16 h-16 object-cover rounded-lg bg-gray-100 flex-shrink-0">
                            <% } else { %>
                                <div class="w-16 h-16 bg-gray-200 rounded-lg flex items-center justify-center text-gray-400 flex-shrink-0">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                </div>
                            <% } %>
                            <div class="flex-1">
                                <p class="text-sm font-bold"><%= item.product_name %></p>
                                <p class="text-xs text-gray-500">Qty: <%= item.quantity %> &times; KES <%= Number(item.price).toLocaleString() %></p>
                                <p class="text-sm font-bold mt-1">KES <%= (item.quantity * item.price).toLocaleString() %></p>
                            </div>
                    <% }); %>
                </div>
                <div class="border-t border-gray-200 mt-4 pt-4 flex justify-between items-center">
                    <span class="text-lg font-bold uppercase">Cart Total</span>
                    <span class="text-2xl font-black">KES <%= items.reduce(function(sum, i) { return sum + (i.quantity * i.price); }, 0).toLocaleString() %></span>
                </div>
            <% } %>
        </div>

    <!-- Customer Info -->
    <div class="space-y-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4">Customer Info</h3>
            <% if (cart.customer_name) { %>
                <div class="space-y-2">
                    <div class="flex justify-between">
                        <span class="text-sm text-gray-500">Name</span>
                        <span class="text-sm font-bold"><%= cart.customer_name %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-sm text-gray-500">Phone</span>
                        <span class="text-sm font-bold"><%= cart.customer_phone || '&mdash;' %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-sm text-gray-500">Address</span>
                        <span class="text-sm font-bold text-right max-w-xs"><%= cart.customer_address || '&mdash;' %></span>
                    </div>
            <% } else { %>
                <p class="text-sm text-gray-400">No customer details captured yet.</p>
            <% } %>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4">Cart Status</h3>
            <span class="text-lg px-3 py-1.5 rounded-full font-bold inline-block
                <%= cart.status === 'active' ? 'bg-blue-100 text-blue-800' : '' %>
                <%= cart.status === 'abandoned' ? 'bg-orange-100 text-orange-800' : '' %>
                <%= cart.status === 'converted' ? 'bg-green-100 text-green-800' : '' %>
            ">
                <%= cart.status.charAt(0).toUpperCase() + cart.status.slice(1) %>
            </span>
            <p class="text-xs text-gray-400 mt-3">Last activity: <%= new Date(cart.updated_at).toLocaleDateString() %></p>
            <p class="text-xs text-gray-400">Session ID: <code class="bg-gray-100 px-1 rounded"><%= cart.session_id %></code></p>
        </div>
</div>

<%- include('partials/admin-foot') %>
