<% currentPage = 'carts'; %>
<%- include('partials/admin-head') %>

<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-3xl font-extrabold tracking-tighter uppercase">Carts &amp; Analytics</h1>
        <p class="text-gray-500 text-sm mt-1">Monitor active, abandoned, and converted carts.</p>
    </div>

<!-- Stats Cards -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
        <p class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-1">Active Carts</p>
        <p class="text-3xl font-black text-blue-600"><%= stats.active || 0 %></p>
        <p class="text-xs text-gray-400 mt-1">Customers currently shopping</p>
    </div>
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
        <p class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-1">Abandoned Carts</p>
        <p class="text-3xl font-black text-orange-600"><%= stats.abandoned || 0 %></p>
        <p class="text-xs text-gray-400 mt-1">Left without ordering</p>
    </div>
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
        <p class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-1">Converted Carts</p>
        <p class="text-3xl font-black text-green-600"><%= stats.converted || 0 %></p>
        <p class="text-xs text-gray-400 mt-1">Successfully ordered</p>
    </div>

<!-- Status Filter -->
<div class="flex flex-wrap gap-2 mb-6">
    <a href="/admin/carts" class="px-4 py-2 rounded-lg text-sm font-bold uppercase tracking-wider <%= currentStatus === 'all' ? 'bg-black text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50' %>">All</a>
    <a href="/admin/carts?status=active" class="px-4 py-2 rounded-lg text-sm font-bold uppercase tracking-wider <%= currentStatus === 'active' ? 'bg-blue-500 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50' %>">Active</a>
    <a href="/admin/carts?status=abandoned" class="px-4 py-2 rounded-lg text-sm font-bold uppercase tracking-wider <%= currentStatus === 'abandoned' ? 'bg-orange-500 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50' %>">Abandoned</a>
    <a href="/admin/carts?status=converted" class="px-4 py-2 rounded-lg text-sm font-bold uppercase tracking-wider <%= currentStatus === 'converted' ? 'bg-green-500 text-white' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50' %>">Converted</a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-100">
                    <th class="text-left py-4 px-6 font-bold text-gray-500 uppercase tracking-wider text-xs">Cart #</th>
                    <th class="text-left py-4 px-6 font-bold text-gray-500 uppercase tracking-wider text-xs">Customer</th>
                    <th class="text-left py-4 px-6 font-bold text-gray-500 uppercase tracking-wider text-xs">Items</th>
                    <th class="text-left py-4 px-6 font-bold text-gray-500 uppercase tracking-wider text-xs">Total</th>
                    <th class="text-left py-4 px-6 font-bold text-gray-500 uppercase tracking-wider text-xs">Status</th>
                    <th class="text-left py-4 px-6 font-bold text-gray-500 uppercase tracking-wider text-xs">Last Activity</th>
                    <th class="text-right py-4 px-6 font-bold text-gray-500 uppercase tracking-wider text-xs">Details</th>
                </tr>
            </thead>
            <tbody>
                <% if (carts.length === 0) { %>
                    <tr>
                        <td colspan="7" class="py-12 text-center text-gray-400">
                            <p class="font-medium">No carts tracked yet</p>
                            <p class="text-xs text-gray-400 mt-1">Carts will appear here when customers visit the checkout page.</p>
                        </td>
                    </tr>
                <% } else { %>
                    <% carts.forEach(function(cart) { %>
                        <tr class="border-b border-gray-50 hover:bg-gray-50 transition">
                            <td class="py-4 px-6 font-bold">#<%= cart.id %></td>
                            <td class="py-4 px-6"><%= cart.customer_name || 'Guest' %></td>
                            <td class="py-4 px-6"><%= cart.item_count %></td>
                            <td class="py-4 px-6 font-bold">KES <%= Number(cart.cart_total).toLocaleString() %></td>
                            <td class="py-4 px-6">
                                <span class="text-xs px-2 py-1 rounded-full font-medium 
                                    <%= cart.status === 'active' ? 'bg-blue-100 text-blue-800' : '' %>
                                    <%= cart.status === 'abandoned' ? 'bg-orange-100 text-orange-800' : '' %>
                                    <%= cart.status === 'converted' ? 'bg-green-100 text-green-800' : '' %>
                                ">
                                    <%= cart.status.charAt(0).toUpperCase() + cart.status.slice(1) %>
                                </span>
                            </td>
                            <td class="py-4 px-6 text-xs text-gray-500"><%= new Date(cart.updated_at).toLocaleDateString() %></td>
                            <td class="py-4 px-6 text-right">
                                <a href="/admin/carts/<%= cart.id %>" class="text-xs font-bold text-black hover:underline">View</a>
                            </td>
                        </tr>
                    <% }); %>
                <% } %>
            </tbody>
        </table>
    </div>

<%- include('partials/admin-foot') %>
