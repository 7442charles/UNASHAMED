<% currentPage = 'dashboard'; %>
<%- include('partials/admin-head') %>

<!-- Page Header -->
<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-3xl font-extrabold tracking-tighter uppercase">Dashboard</h1>
        <p class="text-gray-500 text-sm mt-1">Welcome back, <%= admin.name %>! Here's your store overview.</p>
    </div>
    <span class="text-xs text-gray-400"><%= new Date().toLocaleDateString('en-KE', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
</div>

<!-- Stats Grid -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
        <div class="flex items-center justify-between mb-4">
            <p class="text-sm font-bold text-gray-500 uppercase tracking-wider">Total Products</p>
            <span class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
            </span>
        </div>
        <p class="text-3xl font-black"><%= stats.totalProducts %></p>
    </div>

    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
        <div class="flex items-center justify-between mb-4">
            <p class="text-sm font-bold text-gray-500 uppercase tracking-wider">Collections</p>
            <span class="w-10 h-10 bg-purple-50 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            </span>
        </div>
        <p class="text-3xl font-black"><%= stats.totalCollections %></p>
    </div>

    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
        <div class="flex items-center justify-between mb-4">
            <p class="text-sm font-bold text-gray-500 uppercase tracking-wider">Total Orders</p>
            <span class="w-10 h-10 bg-green-50 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
            </span>
        </div>
        <p class="text-3xl font-black"><%= stats.totalOrders %></p>
        <p class="text-xs text-gray-400 mt-1"><%= stats.pendingOrders %> pending</p>
    </div>

    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
        <div class="flex items-center justify-between mb-4">
            <p class="text-sm font-bold text-gray-500 uppercase tracking-wider">Total Revenue</p>
            <span class="w-10 h-10 bg-yellow-50 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </span>
        </div>
        <p class="text-3xl font-black">KES <%= Number(stats.totalRevenue).toLocaleString() %></p>
    </div>
</div>

<!-- Today + Abandoned Carts -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
        <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4">Today's Stats</h3>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <p class="text-2xl font-black"><%= stats.todayOrders %></p>
                <p class="text-xs text-gray-500">Orders Today</p>
            </div>
            <div>
                <p class="text-2xl font-black">KES <%= Number(stats.todayRevenue).toLocaleString() %></p>
                <p class="text-xs text-gray-500">Revenue Today</p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider">Cart Abandonment</h3>
            <a href="/admin/carts" class="text-xs text-black font-bold hover:underline">View All</a>
        </div>
        <div>
            <p class="text-2xl font-black text-orange-600"><%= stats.abandonedCarts %></p>
            <p class="text-xs text-gray-500">Abandoned Carts</p>
        </div>
    </div>
</div>

<!-- Weekly Chart & Recent Orders -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Weekly Orders Chart -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
        <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4">Last 7 Days Orders</h3>
        <div class="space-y-3">
            <% if (weeklyOrders.length === 0) { %>
                <p class="text-gray-400 text-sm">No orders in the last 7 days.</p>
            <% } else { %>
                <% weeklyOrders.forEach(function(day) { %>
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-gray-600"><%= new Date(day.date).toLocaleDateString('en-KE', { weekday: 'short', month: 'short', day: 'numeric' }) %></span>
                        <div class="flex items-center gap-4">
                            <span class="text-sm font-bold"><%= day.count %> orders</span>
                            <span class="text-sm text-gray-500">KES <%= Number(day.revenue).toLocaleString() %></span>
                        </div>
                    </div>
                    <div class="w-full bg-gray-100 rounded-full h-2">
                        <div class="bg-black h-2 rounded-full" style="width: <%= Math.min((day.count / 10) * 100, 100) %>%"></div>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </div>

    <!-- Recent Orders -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider">Recent Orders</h3>
            <a href="/admin/orders" class="text-xs text-black font-bold hover:underline">View All</a>
        </div>
        <% if (recentOrders.length === 0) { %>
            <p class="text-gray-400 text-sm">No orders yet.</p>
        <% } else { %>
            <div class="space-y-3">
                <% recentOrders.forEach(function(order) { %>
                    <a href="/admin/orders/<%= order.id %>" class="block p-3 rounded-lg hover:bg-gray-50 transition">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-sm font-bold"><%= order.customer_name %></p>
                                <p class="text-xs text-gray-500">KES <%= Number(order.total).toLocaleString() %></p>
                            </div>
                            <span class="text-xs px-2 py-1 rounded-full font-medium 
                                <%= order.status === 'pending' ? 'bg-yellow-100 text-yellow-800' : '' %>
                                <%= order.status === 'confirmed' ? 'bg-blue-100 text-blue-800' : '' %>
                                <%= order.status === 'shipped' ? 'bg-purple-100 text-purple-800' : '' %>
                                <%= order.status === 'delivered' ? 'bg-green-100 text-green-800' : '' %>
                                <%= order.status === 'cancelled' ? 'bg-red-100 text-red-800' : '' %>
                            ">
                                <%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
                            </span>
                        </div>
                    </a>
                <% }); %>
            </div>
        <% } %>
    </div>
</div>

<%- include('partials/admin-foot') %>
