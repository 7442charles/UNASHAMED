<% currentPage = 'collections'; 
   var isEdit = typeof collection !== 'undefined' && collection !== null; %>
<%- include('partials/admin-head') %>

<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-3xl font-extrabold tracking-tighter uppercase"><%= isEdit ? 'Edit' : 'Add' %> Collection</h1>
        <p class="text-gray-500 text-sm mt-1"><%= isEdit ? 'Update collection details' : 'Create a new collection' %></p>
    </div>
    <a href="/admin/collections" class="text-sm text-gray-500 hover:text-black transition font-medium">&larr; Back to Collections</a>
</div>

<% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm font-medium"><%= error %></div>
<% } %>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
    <form action="/admin/collections/save<%= isEdit ? '/' + collection.id : '' %>" method="POST" class="space-y-6 max-w-2xl">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-1.5">Collection Name *</label>
                <input type="text" name="name" required value="<%= isEdit ? collection.name : '' %>" class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-black focus:border-black outline-none" placeholder="e.g. Core Essentials">
            </div>
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-1.5">Slug *</label>
                <input type="text" name="slug" required value="<%= isEdit ? collection.slug : '' %>" class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-black focus:border-black outline-none" placeholder="e.g. core-essentials">
            </div>
        </div>

        <div>
            <label class="block text-sm font-bold text-gray-700 mb-1.5">Description</label>
            <textarea name="description" rows="3" class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-black focus:border-black outline-none resize-none" placeholder="Collection description..."><%= isEdit && collection.description ? collection.description : '' %></textarea>
        </div>

        <div>
            <label class="block text-sm font-bold text-gray-700 mb-1.5">Image URL</label>
            <input type="text" name="image" value="<%= isEdit && collection.image ? collection.image : '' %>" class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-black focus:border-black outline-none" placeholder="https://images.unsplash.com/...">
        </div>

        <div>
            <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-gray-50 transition w-fit">
                <input type="checkbox" name="is_active" value="1" <%= (isEdit && collection.is_active) || !isEdit ? 'checked' : '' %> class="w-4 h-4 accent-black">
                <span class="text-sm font-medium">Active (visible on store)</span>
            </label>
        </div>

        <div class="flex items-center gap-4 pt-4 border-t border-gray-100">
            <button type="submit" class="bg-black text-white px-8 py-3 rounded-lg font-bold uppercase tracking-wider text-sm hover:bg-gray-800 transition">
                <%= isEdit ? 'Update Collection' : 'Create Collection' %>
            </button>
            <a href="/admin/collections" class="text-sm text-gray-500 hover:text-black transition font-medium">Cancel</a>
        </div>
    </form>
</div>

<%- include('partials/admin-foot') %>
